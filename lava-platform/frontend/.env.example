# Vite dev proxy targets (used only during `npm run dev`)
VITE_API_TARGET=http://localhost:8080
VITE_WS_TARGET=ws://localhost:8080

# Session token for local development (in production this comes from the
# operator's backend via ?token= URL param or Telegram start_param)
VITE_DEV_TOKEN=

# WebSocket URL override (leave blank to use the Vite proxy /ws path)
VITE_WS_URL=

# ── Telegram Mini App ─────────────────────────────────────────────
# In production the token comes from Telegram initData exchange.
# For local dev without Telegram, paste a token here (from /api/v1/provider/session/create).
VITE_DEV_TOKEN=

# Public HTTPS URL of the backend (needed when Vite proxy isn't available,
# e.g. when the frontend is served directly from Telegram).
# Leave blank during `npm run dev` — the Vite proxy handles /api and /ws.
VITE_API_URL=

# ── Server ───────────────────────────────────────────────────────
PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=15s
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
ALLOWED_ORIGINS=*

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=lava
POSTGRES_PASSWORD=lava
POSTGRES_DB=lava

DATABASE_URL=postgres://lava:lava@postgres:5432/lava?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MIN_OPEN_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_HEALTH_CHECK_PERIOD=30s

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# ── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@lava.local
PGADMIN_PASSWORD=admin

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

# ── Operator ─────────────────────────────────────────────────────
SYSTEM_API_KEY=change-me-in-production
OPERATOR_SESSION_TTL=24h
OPERATOR_CACHE_TTL=5m

# ── Telegram Mini App ─────────────────────────────────────────────
# Get your bot token from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Must match the operator ID seeded by migrations/008_seed_tma_operator.sql
TELEGRAM_TMA_OPERATOR_ID=1
# Public HTTPS URL of your app (ngrok URL during dev, prod domain in prod)
# Set this via BotFather → /setminiapp → menu button URL
TELEGRAM_APP_URL=https://your-ngrok-url.ngrok.io
# How long Telegram auth timestamps remain valid (default: 24h)
TELEGRAM_AUTH_MAX_AGE=24h
